<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane id="AnchorPane" prefHeight="500.0" prefWidth="800.0" styleClass="mainFxmlClass" stylesheets="@vistalogin.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.VistaAdminController">
    <children>
        <AnchorPane prefHeight="500.0" prefWidth="400.0" styleClass="panel-izquierdo">
           <children>
              <ImageView fitHeight="500.0" fitWidth="400.0" pickOnBounds="true" preserveRatio="false" />
           </children>
        </AnchorPane>
        
        <AnchorPane layoutX="400.0" prefHeight="500.0" prefWidth="400.0">
            <children>
                <Label layoutX="35.0" layoutY="60.0" styleClass="titulo-principal" text="Acceso Administrador" />
                <Label layoutX="100.0" layoutY="110.0" styleClass="subtitulo" text="Accede para gestionar la tienda" />
                
                <TextField layoutX="40.0" layoutY="170.0" prefHeight="45.0" prefWidth="320.0" promptText="Usuario Administrativo" styleClass="campo-texto" />
                <ImageView fitHeight="20.0" fitWidth="20.0" layoutX="55.0" layoutY="183.0" opacity="0.4" pickOnBounds="true" preserveRatio="true" />
                
                <PasswordField layoutX="40.0" layoutY="240.0" prefHeight="45.0" prefWidth="320.0" promptText="Contraseña" styleClass="campo-texto" />
                <ImageView fitHeight="20.0" fitWidth="20.0" layoutX="55.0" layoutY="253.0" opacity="0.4" pickOnBounds="true" preserveRatio="true" />
                
                <CheckBox layoutX="50.0" layoutY="300.0" mnemonicParsing="false" styleClass="check-box" text="Recordarme" />
                
                <Button layoutX="40.0" layoutY="340.0" mnemonicParsing="false" prefHeight="45.0" prefWidth="320.0" styleClass="boton-principal" text="Iniciar Sesión" />
                
                <VBox alignment="CENTER" layoutX="40.0" layoutY="400.0" prefWidth="320.0" spacing="5.0">
                   <children>
                      <Hyperlink styleClass="hyperlink" text="¿Olvidaste tu contraseña?" />
                      <Hyperlink fx:id="linkVolver" onAction="#volverAlLogin" styleClass="hyperlink" text="Volver al Login de Cliente" />
                   </children>
                </VBox>
            </children>
        </AnchorPane>
    </children>
</AnchorPane>
