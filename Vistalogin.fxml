<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane id="AnchorPane" prefHeight="500.0" prefWidth="800.0" styleClass="mainFxmlClass" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.VistaloginController">
    <stylesheets>
        <URL value="@/vistas/vistalogin.css" />
    </stylesheets>
    <children>
        <!-- Mitad Izquierda (Fondo Azul) -->
        <AnchorPane layoutX="-92.0" prefHeight="500.0" prefWidth="400.0" styleClass="panel-izquierdo" />
        
        <!-- Mitad Derecha (Formulario) -->
        <AnchorPane layoutX="400.0" prefHeight="500.0" prefWidth="400.0" stylesheets="@vistalogin.css">
            <children>
                <Label layoutX="40.0" layoutY="70.0" styleClass="titulo-principal" text="Iniciar Sesión" />
                <Label layoutX="40.0" layoutY="120.0" styleClass="subtitulo" text="Ingresa tus datos para continuar" />
                
                <TextField layoutX="40.0" layoutY="190.0" prefHeight="45.0" prefWidth="320.0" promptText="Usuario" styleClass="campo-texto" />
                <PasswordField layoutX="40.0" layoutY="260.0" prefHeight="45.0" prefWidth="320.0" promptText="Contraseña" styleClass="campo-texto" />
                
                <CheckBox layoutX="50.0" layoutY="325.0" mnemonicParsing="false" styleClass="check-box" text="Recordarme" />
                
                <Button layoutX="40.0" layoutY="380.0" mnemonicParsing="false" prefHeight="45.0" prefWidth="320.0" styleClass="boton-principal" text="Iniciar Sesión" />
            </children>
        </AnchorPane>
    </children>
</AnchorPane>
